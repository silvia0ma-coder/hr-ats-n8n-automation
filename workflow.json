    {
      "parameters": {
        "jsCode": "// Get the AI's raw output text\nconst rawOutput = $input.first().json.output;\n\n// Clean it up - remove markdown code blocks if AI added them\nconst cleaned = rawOutput\n  .replace(/```json/gi, '')\n  .replace(/```/g, '')\n  .trim();\n\n// Parse it into a proper JSON object\nconst parsed = JSON.parse(cleaned);\n\n// Return it cleanly for the next nodes to use\nreturn [{ json: parsed }];"
      },
